// -------------------- UTILITAIRES --------------------
void clean_input(char *str) {
    str[strcspn(str,"\r\n")] = 0;  // supprime \n et \r
}

int db_execute(sqlite3 *db, const char *sql) {
    char *err = NULL;
    int rc = sqlite3_exec(db, sql, 0, 0, &err);
    if (rc != SQLITE_OK) {
        printf("SQL ERROR: %s\n", err);
        sqlite3_free(err);
        return 0;
    }
    return 1;
}

