void assignGateDB(sqlite3 *db){
    int flight_id;
    printf("ID vol: "); 
    scanf("%d",&flight_id);

    const char *find="SELECT id FROM gates WHERE status='Libre' LIMIT 1;";
    sqlite3_stmt *stmt;
    if(sqlite3_prepare_v2(db, find, -1, &stmt, 0)!=SQLITE_OK){
        printf("Erreur SQL assignGate\n"); return;
    }
    int rc = sqlite3_step(stmt);
    if(rc==SQLITE_ROW){
        int gate_id = sqlite3_column_int(stmt,0);
        char sql[128];
        sprintf(sql,"UPDATE gates SET status='Occupee', flight_id=%d WHERE id=%d;",flight_id,gate_id);
        db_execute(db, sql);
        printf("Gate %d assignee au vol %d.\n", gate_id, flight_id);
    } else printf("\nAucune gate libre.\n");
    sqlite3_finalize(stmt);
}

void releaseGateDB(sqlite3 *db) {
    char code[10];
    printf("Entrez le code de la porte a liberer (ex: A1) : ");
    scanf("%s", code);

    char sql[128];
    // On remet la porte à l'état initial
    sprintf(sql, "UPDATE gates SET status='Libre', flight_id=id WHERE code='%s';", code);

    if(sqlite3_exec(db, sql, 0, 0, NULL) == SQLITE_OK) {
        printf(" La porte %s est maintenant LIBRE. \n", code);
    } else {
        printf("Erreur lors de la liberation de la porte.\n");
    }

    
    while(getchar() != '\n'); // Vide le buffer du scanf
    getchar();
}

  

