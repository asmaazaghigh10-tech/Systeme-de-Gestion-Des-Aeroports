void addSecurityDB(sqlite3 *db){
    int passenger_id, interdit; char cin[20];
    printf("ID passager: "); scanf("%d",&passenger_id); getchar();
    printf("CIN: "); fgets(cin,20,stdin); cin[strcspn(cin,"\n")]=0;
    printf("Interdit (0/1): "); scanf("%d",&interdit);

    char sql[256];
    sprintf(sql,"INSERT INTO security(passenger_id,cin,interdit) VALUES(%d,'%s',%d);",passenger_id,cin,interdit);
    if(db_execute(db, sql)) printf("\nPassager ajouté.\n");

     while(getchar() != '\n'); // Vide le buffer du scanf
    getchar();
}

void checkSecurityDB(sqlite3 *db){
    int passenger_id; printf("ID passager: "); scanf("%d",&passenger_id);
    const char *sql = "SELECT interdit FROM security WHERE passenger_id=?;";
    sqlite3_stmt *stmt;
    if(sqlite3_prepare_v2(db, sql, -1, &stmt, 0)!=SQLITE_OK){ printf("Erreur SQL\n"); return; }
    sqlite3_bind_int(stmt,1,passenger_id);
    if(sqlite3_step(stmt)==SQLITE_ROW){
        int interdit = sqlite3_column_int(stmt,0);
        if(interdit) printf("Passager interdit d'embarquement.\n");
        else printf("Passager autorise.\n");
    } else printf("Passager non trouve.\n");
    sqlite3_finalize(stmt);

    while(getchar() != '\n'); // Vide le buffer du scanf
    getchar();
}

 void showSecurityDB(sqlite3 *db){
    const char *sql = "SELECT passenger_id, cin, interdit FROM security;";
    
    printSecurityHeader(); // Affiche l'en-tête propre

    // IMPORTANT : On utilise printSecurityRow pour ne pas planter
    if(sqlite3_exec(db, sql, printSecurityRow, 0, NULL) != SQLITE_OK)
        fprintf(stderr, "Erreur affichage securite: %s\n", sqlite3_errmsg(db));
}
