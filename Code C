// -------------------- VOLS --------------------
void addFlightDB(sqlite3 *db) {
    char num[10], org[50], dest[50], dep[20], arr[20], status[20];
    printf("Num Vol: "); fgets(num, 10, stdin); clean_input(num);
    printf("Origine: "); fgets(org, 50, stdin); clean_input(org);
    printf("Destination: "); fgets(dest, 50, stdin); clean_input(dest);
    printf("Date depart (YYYY-MM-DD HH:MM): "); fgets(dep, 20, stdin); clean_input(dep);
    printf("Date arrivee (YYYY-MM-DD HH:MM): "); fgets(arr, 20, stdin); clean_input(arr);
    printf("Status (On-Time/Delayed/Cancelled): "); fgets(status, 20, stdin); clean_input(status);

    char sql[512];
    sprintf(sql,"INSERT INTO flights(num_vol, origine, destination, date_dep, date_arr, status) "
                "VALUES('%s','%s','%s','%s','%s','%s');",
                num, org, dest, dep, arr, status);
    if (db_execute(db, sql)) printf("\nVol ajoute.\n");

    
    while(getchar() != '\n'); // Vide le buffer du scanf
    getchar();
}

void deleteFlightDB(sqlite3 *db) {
    int id; printf("ID du vol a supprimer: "); scanf("%d",&id); getchar();
    char sql[128]; sprintf(sql,"DELETE FROM flights WHERE id=%d;", id);
    if (db_execute(db, sql)) printf("\nVol supprime.\n");

    
    while(getchar() != '\n'); // Vide le buffer du scanf
    getchar();
}

void updateFlightStatusDB(sqlite3 *db) {
    int id; char status[20];
    printf("ID du vol: ");
    scanf("%d",&id);
    getchar();
    printf("Nouveau status (On-Time/Delayed/Cancelled): ");
    fgets(status, 20, stdin); 
    clean_input(status);
    char sql[128]; sprintf(sql,"UPDATE flights SET status='%s' WHERE id=%d;", status, id);
    if (db_execute(db, sql)) printf("\nStatus mis a jour.\n");

    
    while(getchar() != '\n'); // Vide le buffer du scanf
    getchar();
}

void showFlightsDB(sqlite3 *db) {
    const char *sql = "SELECT * FROM flights;";
    printFlightHeader();
    if (sqlite3_exec(db, sql, printRow, 0, NULL) != SQLITE_OK)
        fprintf(stderr,"Erreur affichage vols: %s\n", sqlite3_errmsg(db));}

